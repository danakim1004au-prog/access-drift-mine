# Secrets template for connecting the Access Drift dashboard locally
#
# How to use:
#   1) Copy this file to secrets.toml in the same folder.
#        cp secrets.toml.example secrets.toml
#   2) Fill in the values below (especially access_token) with your own.
#   3) secrets.toml is listed in .gitignore, so it won't be committed. (Never commit your token.)
#
# Getting an access_token: log in to your Databricks workspace
#   → profile menu (top right) → Settings → Developer → Access tokens → Generate new token
#   (or, if the Databricks CLI is set up locally, you can reuse the token from ~/.databrickscfg)

[databricks]
server_hostname = "adb-7405615323116390.10.azuredatabricks.net"
http_path       = "/sql/1.0/warehouses/8baac3b353ebbda4"   # Find under SQL Warehouses > Starter Warehouse > Connection details
access_token    = "dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXX"        # Swap in your own PAT
catalog         = "access_drift_dev"
gold_schema     = "gold"
app_schema      = "app"

# The generative LLM endpoint used by the AI Agent chatbot.
# If left out, it uses databricks-meta-llama-3-3-70b-instruct (the built-in workspace FM API, no external key or personal billing needed).
# To switch to Claude or similar, just change this value: e.g. databricks-claude-sonnet-5
llm_endpoint    = "databricks-meta-llama-3-3-70b-instruct"
